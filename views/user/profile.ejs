<%- include('../partials/header') %>

<div class="page-header">
  <div class="container"><h1>My Profile</h1></div>
</div>

<section class="section">
  <div class="container">
    <div class="dashboard-layout">
      <aside class="dash-sidebar">
        <div class="dash-user">
          <img src="/images/default-avatar.png" alt="" class="dash-user__avatar"/>
          <div><strong><%= user.name %></strong><p><%= user.email %></p></div>
        </div>
        <nav class="dash-nav">
          <a href="/user/dashboard" class="dash-nav__link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
          <a href="/user/bookings" class="dash-nav__link"><i class="fas fa-calendar-check"></i> My Bookings</a>
          <a href="/user/profile" class="dash-nav__link active"><i class="fas fa-user-edit"></i> Profile</a>
          <a href="/bikes" class="dash-nav__link"><i class="fas fa-bicycle"></i> Browse Bikes</a>
          <a href="/auth/logout" class="dash-nav__link dash-nav__link--danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
      </aside>
      <main class="dash-main">
        <div class="profile-grid">
          <!-- Update Profile -->
          <div class="profile-card">
            <h3><i class="fas fa-user-edit"></i> Personal Information</h3>
            <form action="/user/profile/update" method="POST">
              <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" class="input" value="<%= profile.name %>" required/>
              </div>
              <div class="form-group">
                <label>Email</label>
                <input type="email" class="input" value="<%= profile.email %>" disabled/>
                <small><% if (profile.isVerified) { %><span class="text--success"><i class="fas fa-check-circle"></i> Verified</span><% } %></small>
              </div>
              <div class="form-group">
                <label>Phone</label>
                <input type="tel" name="phone" class="input" value="<%= profile.phone || '' %>"/>
              </div>
              <div class="form-group">
                <label>City</label>
                <select name="city" class="input">
                  <option value="">Select City</option>
                  <% ['Mumbai','Delhi','Bangalore','Hyderabad','Chennai','Pune','Kolkata','Jaipur','Goa','Manali'].forEach(c => { %>
                    <option value="<%= c %>" <%= profile.city === c ? 'selected':'' %>><%= c %></option>
                  <% }) %>
                </select>
              </div>
              <button type="submit" class="btn btn--primary">Save Changes</button>
            </form>
          </div>

          <!-- Change Password -->
          <div class="profile-card">
            <h3><i class="fas fa-lock"></i> Change Password</h3>
            <form action="/user/profile/password" method="POST">
              <div class="form-group">
                <label>Current Password</label>
                <input type="password" name="current" class="input" placeholder="Current password"/>
              </div>
              <div class="form-group">
                <label>New Password</label>
                <input type="password" name="newPass" class="input" placeholder="New password" minlength="6"/>
              </div>
              <div class="form-group">
                <label>Confirm New Password</label>
                <input type="password" name="confirm" class="input" placeholder="Confirm password"/>
              </div>
              <button type="submit" class="btn btn--primary">Update Password</button>
            </form>
          </div>
        </div>

        <!-- Account Info -->
        <div class="profile-card profile-card--info">
          <h3><i class="fas fa-info-circle"></i> Account Info</h3>
          <div class="info-grid">
            <div><span>Member Since</span><strong><%= new Date(profile.createdAt).toLocaleDateString('en-IN') %></strong></div>
            <div><span>Account Type</span><strong><%= profile.role.toUpperCase() %></strong></div>
            <div><span>Email Verified</span><strong><%= profile.isVerified ? '✅ Yes' : '❌ No' %></strong></div>
            <div><span>Total Bookings</span><strong><%= profile.bookings.length %></strong></div>
          </div>
        </div>
      </main>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
