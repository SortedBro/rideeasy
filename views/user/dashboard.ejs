<%- include('../partials/header') %>

<div class="page-header">
  <div class="container">
    <h1>My Dashboard</h1>
    <p>Welcome back, <strong><%= user.name %></strong>! 👋</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="dashboard-layout">

      <!-- Sidebar -->
      <aside class="dash-sidebar">
        <div class="dash-user">
          <img src="/images/default-avatar.png" alt="" class="dash-user__avatar"/>
          <div>
            <strong><%= user.name %></strong>
            <p><%= user.email %></p>
          </div>
        </div>
        <nav class="dash-nav">
          <a href="/user/dashboard" class="dash-nav__link active"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
          <a href="/user/bookings" class="dash-nav__link"><i class="fas fa-calendar-check"></i> My Bookings</a>
          <a href="/user/profile" class="dash-nav__link"><i class="fas fa-user-edit"></i> Profile</a>
          <a href="/bikes" class="dash-nav__link"><i class="fas fa-bicycle"></i> Browse Bikes</a>
          <a href="/auth/logout" class="dash-nav__link dash-nav__link--danger"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
      </aside>

      <!-- Main Content -->
      <main class="dash-main">
        <!-- Stats -->
        <div class="dash-stats">
          <div class="dash-stat"><i class="fas fa-calendar-alt"></i><div><strong><%= stats.total %></strong><span>Total Bookings</span></div></div>
          <div class="dash-stat dash-stat--active"><i class="fas fa-bicycle"></i><div><strong><%= stats.active %></strong><span>Active</span></div></div>
          <div class="dash-stat dash-stat--success"><i class="fas fa-check-circle"></i><div><strong><%= stats.completed %></strong><span>Completed</span></div></div>
          <div class="dash-stat dash-stat--danger"><i class="fas fa-times-circle"></i><div><strong><%= stats.cancelled %></strong><span>Cancelled</span></div></div>
        </div>

        <!-- Recent Bookings -->
        <div class="dash-section">
          <div class="dash-section__header">
            <h3>Recent Bookings</h3>
            <a href="/user/bookings" class="btn btn--outline btn--sm">View All</a>
          </div>
          <% if (bookings.length === 0) { %>
            <div class="empty-state empty-state--sm">
              <i class="fas fa-calendar-times"></i>
              <h4>No bookings yet</h4>
              <a href="/bikes" class="btn btn--primary btn--sm">Browse Bikes</a>
            </div>
          <% } else { %>
          <div class="bookings-table-wrap">
            <table class="bookings-table">
              <thead><tr><th>Bike</th><th>Dates</th><th>Amount</th><th>Status</th><th>Action</th></tr></thead>
              <tbody>
              <% bookings.forEach(b => { %>
              <tr>
                <td><div class="table-bike"><img src="<%= b.bike?.images?.[0] || '/images/bike-default.jpg' %>"/><span><%= b.bike?.name %></span></div></td>
                <td><small><%= new Date(b.startDate).toLocaleDateString('en-IN') %> – <%= new Date(b.endDate).toLocaleDateString('en-IN') %></small></td>
                <td><strong>₹<%= b.totalAmount %></strong></td>
                <td><span class="status-badge status-badge--<%= b.status %>"><%= b.status %></span></td>
                <td><a href="/booking/<%= b._id %>" class="btn btn--outline btn--xs">View</a></td>
              </tr>
              <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

        <!-- Quick Actions -->
        <div class="dash-section">
          <h3>Quick Actions</h3>
          <div class="quick-actions">
            <a href="/bikes" class="quick-action"><i class="fas fa-bicycle"></i><span>Rent a Bike</span></a>
            <a href="/user/bookings" class="quick-action"><i class="fas fa-history"></i><span>Booking History</span></a>
            <a href="/user/profile" class="quick-action"><i class="fas fa-user-cog"></i><span>Edit Profile</span></a>
            <a href="/contact" class="quick-action"><i class="fas fa-headset"></i><span>Get Support</span></a>
          </div>
        </div>
      </main>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
