<%- include('partials/header') %>

<div class="page-header">
  <div class="container">
    <h1>About RideEasy</h1>
    <p>India's most trusted bike rental platform</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <span class="section__tag">Our Story</span>
        <h2>Born from a Passion for Adventure</h2>
        <p>RideEasy was founded in 2020 with a simple mission: make bike rental easy, affordable, and accessible across India. Whether you're exploring Goa's beaches, tackling Manali's mountain trails, or commuting through Bangalore's streets — we have the perfect bike for you.</p>
        <p>With 500+ bikes across 15+ cities and 10,000+ happy riders, we're India's fastest-growing bike rental platform.</p>
        <div class="about-stats">
          <div><strong>500+</strong><span>Bikes</span></div>
          <div><strong>15+</strong><span>Cities</span></div>
          <div><strong>10k+</strong><span>Riders</span></div>
          <div><strong>4.8/5</strong><span>Rating</span></div>
        </div>
      </div>
      <div class="about-image">
        <div class="about-image__placeholder"><i class="fas fa-bicycle"></i></div>
      </div>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <div class="section__header">
      <h2>Meet Our Team</h2>
      <p>Passionate riders building the future of bike rental</p>
    </div>
    <div class="team-grid">
      <div class="team-card"><div class="team-card__avatar"><i class="fas fa-user"></i></div><h4>Arjun Sharma</h4><p>CEO & Co-Founder</p></div>
      <div class="team-card"><div class="team-card__avatar"><i class="fas fa-user"></i></div><h4>Priya Nair</h4><p>CTO</p></div>
      <div class="team-card"><div class="team-card__avatar"><i class="fas fa-user"></i></div><h4>Rohit Mehta</h4><p>Operations Head</p></div>
      <div class="team-card"><div class="team-card__avatar"><i class="fas fa-user"></i></div><h4>Sneha Kapoor</h4><p>Customer Success</p></div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
