<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | RideEasy</title>
  <link rel="icon" href="/images/favicon.png" type="image/png"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<!-- ── Flash Messages ──────────────────────────────────── -->
<% if (success && success.length) { %>
<div class="flash flash--success"><i class="fas fa-check-circle"></i> <%= success[0] %><button class="flash__close">&times;</button></div>
<% } %>
<% if (error && error.length) { %>
<div class="flash flash--error"><i class="fas fa-exclamation-circle"></i> <%= error[0] %><button class="flash__close">&times;</button></div>
<% } %>

<!-- ── Navbar ──────────────────────────────────────────── -->
<nav class="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__brand">
      <i class="fas fa-bicycle"></i> RideEasy
    </a>
    <button class="navbar__toggle" id="navToggle"><i class="fas fa-bars"></i></button>
    <ul class="navbar__menu" id="navMenu">
      <li><a href="/" class="navbar__link">Home</a></li>
      <li><a href="/bikes" class="navbar__link">Bikes</a></li>
      <li><a href="/about" class="navbar__link">About</a></li>
      <li><a href="/faq" class="navbar__link">FAQ</a></li>
      <li><a href="/contact" class="navbar__link">Contact</a></li>
      <% if (user) { %>
        <% if (user.role === 'admin') { %>
          <li><a href="/admin/dashboard" class="navbar__link navbar__link--btn">Admin</a></li>
        <% } else { %>
          <li><a href="/user/dashboard" class="navbar__link">Dashboard</a></li>
        <% } %>
        <li><a href="/auth/logout" class="navbar__link navbar__link--btn navbar__link--outline">Logout</a></li>
      <% } else { %>
        <li><a href="/auth/login" class="navbar__link">Login</a></li>
        <li><a href="/auth/register" class="navbar__link navbar__link--btn">Register</a></li>
      <% } %>
    </ul>
  </div>
</nav>
