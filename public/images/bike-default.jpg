<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 280" width="400" height="280">
  <rect width="400" height="280" fill="#f1f5f9"/>
  <circle cx="120" cy="180" r="60" fill="none" stroke="#cbd5e1" stroke-width="8"/>
  <circle cx="120" cy="180" r="10" fill="#94a3b8"/>
  <circle cx="280" cy="180" r="60" fill="none" stroke="#cbd5e1" stroke-width="8"/>
  <circle cx="280" cy="180" r="10" fill="#94a3b8"/>
  <!-- Frame -->
  <line x1="120" y1="180" x2="200" y2="120" stroke="#94a3b8" stroke-width="8" stroke-linecap="round"/>
  <line x1="200" y1="120" x2="280" y2="180" stroke="#94a3b8" stroke-width="8" stroke-linecap="round"/>
  <line x1="200" y1="120" x2="200" y2="80" stroke="#94a3b8" stroke-width="8" stroke-linecap="round"/>
  <line x1="190" y1="80" x2="220" y2="80" stroke="#94a3b8" stroke-width="8" stroke-linecap="round"/>
  <line x1="170" y1="120" x2="200" y2="120" stroke="#94a3b8" stroke-width="8" stroke-linecap="round"/>
  <line x1="170" y1="120" x2="120" y2="180" stroke="#94a3b8" stroke-width="8" stroke-linecap="round"/>
  <!-- Pedals -->
  <circle cx="200" cy="160" r="14" fill="none" stroke="#cbd5e1" stroke-width="6"/>
  <line x1="186" y1="160" x2="170" y2="168" stroke="#94a3b8" stroke-width="5" stroke-linecap="round"/>
  <line x1="214" y1="160" x2="230" y2="152" stroke="#94a3b8" stroke-width="5" stroke-linecap="round"/>
  <!-- Seat -->
  <line x1="200" y1="120" x2="190" y2="100" stroke="#94a3b8" stroke-width="6" stroke-linecap="round"/>
  <line x1="178" y1="97" x2="202" y2="97" stroke="#64748b" stroke-width="8" stroke-linecap="round"/>
  <text x="200" y="255" text-anchor="middle" font-family="system-ui" font-size="14" fill="#94a3b8">RideEasy Bikes</text>
</svg>
